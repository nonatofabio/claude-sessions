# VHS tape file for recording the claude-sessions demo GIF
# Run: vhs assets/demo.tape

Output assets/demo.gif

Set Shell zsh
Set FontSize 14
Set Width 1400
Set Height 800
Set Padding 20
Set Theme "GitHub Dark"
Set TypingSpeed 60ms

# Launch in demo mode
Type "claude-sessions --demo"
Enter
Sleep 3s

# Navigate down — show fork graph lines appearing
Sleep 1s
Type "s"
Sleep 500ms
Type "s"
Sleep 500ms
Type "s"
Sleep 500ms
Type "s"
Sleep 500ms
Type "s"
Sleep 500ms
Type "s"
Sleep 500ms
Type "s"
Sleep 500ms
Type "s"
Sleep 1.5s

# Collapse a group
Type "a"
Sleep 1s

# Navigate up
Type "w"
Sleep 400ms
Type "w"
Sleep 400ms
Type "w"
Sleep 400ms

# Expand
Type "d"
Sleep 1.5s

# Switch to Topic dimension
Type "2"
Sleep 2s

# Navigate through topics
Type "s"
Sleep 400ms
Type "s"
Sleep 400ms
Type "s"
Sleep 400ms
Type "s"
Sleep 1.5s

# Switch to Domain
Type "3"
Sleep 2s

# Navigate — show fork badges (↳) on forked sessions
Type "s"
Sleep 400ms
Type "s"
Sleep 400ms
Type "s"
Sleep 1.5s

# Search
Type "/"
Sleep 500ms
Type "refactor"
Sleep 1.5s
Enter
Sleep 1s

# Navigate search results
Type "s"
Sleep 600ms
Type "s"
Sleep 1s

# Clear search
Escape
Sleep 1.5s

# Back to Project view — best view for fork graphs
Type "1"
Sleep 2s

# Navigate to show fork tree lines
Type "s"
Sleep 400ms
Type "s"
Sleep 400ms
Type "s"
Sleep 400ms
Type "s"
Sleep 400ms
Type "s"
Sleep 400ms
Type "s"
Sleep 400ms
Type "s"
Sleep 400ms
Type "s"
Sleep 400ms
Type "s"
Sleep 2s

# Scroll detail pane with arrows
Down
Sleep 300ms
Down
Sleep 300ms
Down
Sleep 300ms
Up
Sleep 300ms
Up
Sleep 1.5s

# Date dimension
Type "4"
Sleep 2s

# Quick navigation
Type "s"
Sleep 400ms
Type "s"
Sleep 1.5s

# Quit
Type "q"
Sleep 1s
